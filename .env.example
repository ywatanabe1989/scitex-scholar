# scitex-scholar environment variables
#
# `cp .env.example .env` and edit. Loaded automatically when the package
# initializes; explicit kwargs/CLI flags still take precedence.

# SCITEX_SCHOLAR_ALERT_BACKENDS=
# SCITEX_SCHOLAR_CROSSREF_API_URL=
# SCITEX_SCHOLAR_EZPROXY_EMAIL=
# SCITEX_SCHOLAR_FROM_EMAIL_ADDRESS=
# SCITEX_SCHOLAR_FROM_EMAIL_PASSWORD=
# SCITEX_SCHOLAR_FROM_EMAIL_SMTP_PORT=
# SCITEX_SCHOLAR_FROM_EMAIL_SMTP_SERVER=
# SCITEX_SCHOLAR_NOTIFICATION_EMAIL=
# SCITEX_SCHOLAR_OPENALEX_API_URL=
# SCITEX_SCHOLAR_OPENATHENS=
# SCITEX_SCHOLAR_OPENATHENS_EMAIL=
# SCITEX_SCHOLAR_SHIBBOLETH_EMAIL=
# SCITEX_SCHOLAR_SSO_EMAIL=
# SCITEX_SCHOLAR_USE_CACHE_DOWNLOAD=
